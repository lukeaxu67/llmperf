# LLMPerf Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# General Settings
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Database path
# LLMPerf_DB_PATH=/data/llmperf.db

# Static files directory (for production)
# STATIC_DIR=/app/static

# =============================================================================
# LLM Provider API Keys
# =============================================================================

# OpenAI / Azure OpenAI
OPENAI_API_KEY=sk-xxx
OPENAI_BASE_URL=https://api.openai.com/v1

# Qianwen (通义千问)
QIANWEN_API_KEY=sk-xxx
QIANWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Zhipu AI (智谱)
ZHIPU_API_KEY=xxx

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx

# iFlytek (讯飞星火)
IFLYTEK_API_KEY=xxx

# Huoshan (火山引擎)
HUOSHAN_API_KEY=xxx

# Moonshot (月之暗面)
MOONSHOT_API_KEY=xxx

# Tencent Hunyuan (腾讯混元)
HUNYUAN_API_KEY=xxx

# =============================================================================
# Notification Settings (Email)
# =============================================================================

# SMTP settings for email notifications
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-password

# =============================================================================
# Web Interface Settings
# =============================================================================

# Web server host and port
LLMPERF_WEB_HOST=0.0.0.0
LLMPERF_WEB_PORT=8000

# =============================================================================
# Docker Compose Settings
# =============================================================================

# Grafana admin credentials (for monitoring profile)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
